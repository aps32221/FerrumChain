{
  "name": "@ferrum/sdk",
  "version": "0.1.0",
  "description": "Typed third-party SDK for the Ferrum sovereign blockchain (wraps @polkadot/api).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "example": "tsx examples/quickstart.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@polkadot/api": "^15.0.1",
    "@polkadot/keyring": "^13.2.3",
    "@polkadot/util": "^13.2.3",
    "@polkadot/util-crypto": "^13.2.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": { "node": ">=18" }
}
