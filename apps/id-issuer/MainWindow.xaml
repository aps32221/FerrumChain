<Window x:Class="IdIssuer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ferrum 身分證核發終端" Height="660" Width="980"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Microsoft JhengHei UI, Segoe UI, sans-serif">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="400"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ============ Left: issuance form ============ -->
    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Card}"
            CornerRadius="14" Padding="24" Margin="0,0,20,0">
      <Border.Effect>
        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.10" Color="Black"/>
      </Border.Effect>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="核發身分證" FontSize="22" FontWeight="Bold"
                     Foreground="{StaticResource Ink}"/>
          <TextBlock Text="輸入持證人資料，產生數位身分與驗證 QR code。"
                     Foreground="{StaticResource Muted}" FontSize="13" Margin="0,4,0,4"
                     TextWrapping="Wrap"/>

          <TextBlock Text="姓名" Style="{StaticResource FieldLabel}"/>
          <TextBox x:Name="NameBox" Style="{StaticResource Field}"/>

          <TextBlock Text="身分證字號" Style="{StaticResource FieldLabel}"/>
          <TextBox x:Name="IdBox" Style="{StaticResource Field}"/>

          <TextBlock Text="出生日期 (YYYY-MM-DD)" Style="{StaticResource FieldLabel}"/>
          <TextBox x:Name="DobBox" Style="{StaticResource Field}"/>

          <TextBlock Text="國籍" Style="{StaticResource FieldLabel}"/>
          <TextBox x:Name="NatBox" Style="{StaticResource Field}" Text="中華民國"/>

          <TextBlock Text="鏈標籤 (chain tag)" Style="{StaticResource FieldLabel}"/>
          <TextBox x:Name="TagBox" Style="{StaticResource Field}" Text="tw"/>

          <TextBlock Text="發證機關" Style="{StaticResource FieldLabel}"/>
          <TextBox x:Name="IssuerBox" Style="{StaticResource Field}" Text="內政部"/>

          <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="核發" Style="{StaticResource PrimaryButton}"
                    Click="Issue_Click"/>
            <Button Grid.Column="2" Content="清除" Style="{StaticResource GhostButton}"
                    Click="Clear_Click"/>
          </Grid>

          <!-- Optional on-chain anchoring -->
          <Expander Header="進階：DID 上鏈 (選填)" Margin="0,18,0,0"
                    Foreground="{StaticResource Muted}" FontSize="13">
            <StackPanel Margin="0,8,0,0">
              <TextBlock Text="節點端點" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="EndpointBox" Style="{StaticResource Field}"
                       Text="ws://127.0.0.1:9944"/>
              <TextBlock Text="發證機關金鑰 — secret seed (32-byte hex)" Style="{StaticResource FieldLabel}"/>
              <TextBox x:Name="SecretBox" Style="{StaticResource Field}"/>
              <TextBlock Text="公鑰與位址由種子自動推導（ferrum-node key generate 的 Secret seed）。"
                         Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap"
                         Margin="2,4,0,0"/>
              <Button x:Name="AnchorButton" Content="送出 anchor_did 上鏈"
                      Style="{StaticResource GhostButton}" Margin="0,14,0,0"
                      IsEnabled="False" Click="Anchor_Click"/>
            </StackPanel>
          </Expander>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ============ Right: ID card preview ============ -->
    <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Card}"
            CornerRadius="14" VerticalAlignment="Top" ClipToBounds="True">
      <Border.Effect>
        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.10" Color="Black"/>
      </Border.Effect>
      <StackPanel>
        <!-- Header strip -->
        <Border Background="{StaticResource Accent}" CornerRadius="14,14,0,0" Padding="24,20">
          <StackPanel>
            <TextBlock Text="FERRUM" Foreground="White" FontSize="13"
                       FontWeight="Bold" Opacity="0.85"/>
            <TextBlock Text="數位身分證 · Digital Identity Card"
                       Foreground="White" FontSize="20" FontWeight="Bold"/>
          </StackPanel>
        </Border>

        <!-- Body -->
        <Grid Margin="24">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
          </Grid.ColumnDefinitions>

          <!-- Info column -->
          <StackPanel Grid.Column="0" Margin="0,0,16,0">
            <TextBlock x:Name="PvName" Text="—" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Ink}"/>

            <TextBlock Text="身分證字號" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvId" Text="—" FontSize="15" Foreground="{StaticResource Ink}"/>

            <TextBlock Text="出生日期" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvDob" Text="—" FontSize="15" Foreground="{StaticResource Ink}"/>

            <TextBlock Text="國籍" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvNat" Text="—" FontSize="15" Foreground="{StaticResource Ink}"/>

            <TextBlock Text="發證機關" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvIssuer" Text="—" FontSize="15" Foreground="{StaticResource Ink}"/>

            <TextBlock Text="核發日期" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvDate" Text="—" FontSize="15" Foreground="{StaticResource Ink}"/>

            <TextBlock Text="DID" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvDid" Text="—" FontSize="13" TextWrapping="Wrap"
                       Foreground="{StaticResource Accent}"/>

            <TextBlock Text="文件雜湊承諾 (commitment)" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="PvHash" Text="—" FontSize="12" FontFamily="Consolas, monospace"
                       Foreground="{StaticResource Muted}"/>
          </StackPanel>

          <!-- QR column -->
          <StackPanel Grid.Column="1" VerticalAlignment="Top">
            <Border BorderBrush="{StaticResource Line}" BorderThickness="1"
                    CornerRadius="10" Padding="10" Background="White">
              <Grid Width="180" Height="180">
                <TextBlock x:Name="QrPlaceholder" Text="尚未核發"
                           Foreground="{StaticResource Muted}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Image x:Name="QrImage" Stretch="Uniform" Visibility="Collapsed"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
              </Grid>
            </Border>
            <TextBlock Text="掃描以驗證" Foreground="{StaticResource Muted}" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ============ Status bar ============ -->
    <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0">
      <TextBlock x:Name="StatusText" Text="就緒 — 填寫左側資料後按「核發」。"
                 Foreground="{StaticResource Muted}" FontSize="13"/>
    </Border>
  </Grid>
</Window>
